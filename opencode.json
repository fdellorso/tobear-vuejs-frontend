{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", "dist-ssr/**", ".git/**"]
  },
  "permission": {
    "edit": {
      ".opencode/skills/*": "deny",
      ".opencode/commands/*": "deny",
      "opencode.json": "deny",
      ".env*": "deny"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--headless"],
      "enabled": true
    }
  },
  "lsp": {
    "vue": {
      "command": ["npx", "@vue/language-server", "--stdio"],
      "extensions": [".vue", ".js"]
    }
  }
}
